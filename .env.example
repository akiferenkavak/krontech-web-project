# ─── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_DB=krontech
POSTGRES_USER=krontech_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────
REDIS_PASSWORD=your_redis_password
REDIS_PORT=6379

# ─── JWT ──────────────────────────────────────────────────────────
# En az 32 karakter, güçlü rastgele string
JWT_SECRET=your_super_secret_jwt_key_min_32_chars
JWT_EXPIRATION_MS=86400000

# ─── Admin kullanıcı (DataInitializer) ───────────────────────────
APP_ADMIN_EMAIL=admin@krontech.com
APP_ADMIN_PASSWORD=your_admin_password

# ─── Cookie ───────────────────────────────────────────────────────
# Geliştirme: false, Production: true
APP_COOKIE_SECURE=false

# ─── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ─── Revalidate Secret ve Frontend URL ───────────────────────────
REVALIDATE_SECRET=your_revalidate_secret
FRONTEND_URL=http://frontend:3000


# ─── Site URL ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://krontech.com


# reCAPTCHA Ayarları
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# ─── Preview Secret ───────────────────────────────────────────────
# Admin panelinden taslak içerik önizlemek için kullanılır
PREVIEW_SECRET=your_preview_secret_min_32_chars
NEXT_PUBLIC_PREVIEW_SECRET=your_preview_secret_min_32_chars